{
  "name": "pearls",
  "version": "0.1.0",
  "description": "Agent-friendly to-do list manager. CLI wrapper around the Pi `todo` extension storage format.",
  "type": "module",
  "bin": {
    "pearls": "dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pearls": "tsx src/cli.ts",
    "test": "bash test/cli.sh",
    "test:dist": "PEARLS_BIN=dist bash test/cli.sh",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@mariozechner/pi-ai": "^0.70.2",
    "@mariozechner/pi-coding-agent": "^0.70.2",
    "@mariozechner/pi-tui": "^0.70.2",
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
